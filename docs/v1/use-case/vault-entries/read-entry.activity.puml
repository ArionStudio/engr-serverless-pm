@startuml read-entry-activity
title ReadEntryUseCase - Activity

skinparam backgroundColor #FEFEFE
skinparam roundcorner 8
skinparam shadowing false
skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1976D2
}

start
:Input:\nvaultId, entryId;
:Source:\npackages/core/src/use-cases/vault-entries/read-entry.ts;
:Require unlocked vault context for "read entry";
:Find active entry by entryId;
if (entry missing?) then (yes)
  :Throw PasswordEntryNotFoundError;
  stop
endif
:Map entry to visible fields;
note right
Visible fields only:
id, login, tags, sanitizedUrl.
Plaintext password is not returned here.
end note
:Return { entry };
stop
@enduml
