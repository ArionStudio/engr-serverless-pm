@startuml generate-password-activity
title GeneratePasswordUseCase - Activity

skinparam backgroundColor #FEFEFE
skinparam roundcorner 8
skinparam shadowing false
skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1976D2
}

start
:Input:\npartial GeneratedPasswordSettings or defaults;
:Source:\npackages/core/src/use-cases/password-tools/generate-password.ts;
:Validate settings with generatedPasswordSettingsSchema;
if (settings invalid?) then (yes)
  :Throw InvalidGeneratedPasswordSettingsError;
  stop
endif
:Build enabled character sets;
if (settings cannot produce a password?) then (yes)
  :Throw PasswordGenerationImpossibleError;
  stop
endif
:Pick required/generated characters using RandomSamplerService.pickIndex;
:Shuffle generated characters using RandomSamplerService.pickIndex;
:Join characters;
:Return { password };
stop
@enduml
