@startuml generate-username-activity
title GenerateUsernameUseCase - Activity

skinparam backgroundColor #FEFEFE
skinparam roundcorner 8
skinparam shadowing false
skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1976D2
}

start
:Input:\npartial GeneratedUsernameSettings or defaults;
