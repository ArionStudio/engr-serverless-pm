@startuml copy-entry-password-activity
title CopyEntryPasswordUseCase - Activity

skinparam backgroundColor #FEFEFE
skinparam roundcorner 8
skinparam shadowing false
skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1976D2
}

start
:Input:\nvaultId, entryId, clearAfterMs;
:Source:\npackages/core/src/use-cases/clipboard/copy-entry-password.ts;
:Validate clearAfterMs before reading password;
if (invalid delay?) then (yes)
  :Throw InvalidClipboardClearDelayError;
  stop
endif

:Require unlocked vault context for "copy entry password";
:Find active entry by entryId;
if (entry missing?) then (yes)
  :Throw PasswordEntryNotFoundError;
  stop
endif

:Compute clearScheduledAt = now + clearAfterMs;
:Load previous clipboard clear task;
if (previous task exists?) then (yes)
  :Try clear previous copied value\nwith requireExpired = false;
  :Try cancel previous scheduled clearClipboard task;
  if (previous clear failed?) then (yes)
    :Throw previous clear failure after cancel attempt;
    stop
  endif
endif

:Generate new actionId;
:Hash plaintext password for metadata;
note right
Stored clear metadata contains only:
actionId, copiedValueHash, expiresAt.
It does not store the plaintext password.
end note
:Save new clipboard clear task metadata;

if (schedule clearClipboard task succeeds?) then (yes)
  :Continue;
else (no)
  :Remove clipboard clear task metadata;
  :Throw schedule failure;
  stop
endif

if (write plaintext password to clipboard succeeds?) then (yes)
  :Return { copied: true };
  stop
else (no)
  :Best effort cancel scheduled clearClipboard task;
  :Best effort remove clipboard clear task metadata;
  :Throw original clipboard write failure;
  stop
endif
@enduml
