@startuml change-master-password-activity
title ChangeMasterPasswordUseCase - Activity

skinparam backgroundColor #FEFEFE
skinparam roundcorner 8
skinparam shadowing false
skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1976D2
}

start
:Input:\nvaultId, currentMasterPassword, newMasterPassword;
:Source:\npackages/core/src/use-cases/vault-lifecycle/change-master-password.ts;
:Read unlocked vault session;
if (session missing or different vault?) then (yes)
  :Throw VaultMustBeUnlockedForMasterPasswordChangeError;
  stop
endif

:Load device access material;
if (missing?) then (yes)
  :Throw DeviceAccessMaterialNotFoundForMasterPasswordChangeError;
  stop
endif

if (device access material algorithm unsupported?) then (yes)
  :Throw UnsupportedAlgorithmSuiteError;
  stop
endif

:Derive current localRootKey from currentMasterPassword;
:Derive current localKeysProtectionKey;
:Unwrap local keys payload;
:Generate new master password salt;
:Derive new localRootKey from newMasterPassword;
:Generate new local keys protection salt;
:Derive new localKeysProtectionKey;
:Wrap same local keys payload with new protection key;
:Save updated device access material\n(new salts + protectedLocalKeys);
:Return void;
stop
@enduml
