@startuml recover-vault-access-activity
title RecoverVaultAccessUseCase - Activity

skinparam backgroundColor #FEFEFE
skinparam roundcorner 8
skinparam shadowing false
skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1976D2
}

start
:Input:\nvaultId, recoveryMnemonicKey, newMasterPassword, deviceName;
:Source:\npackages/core/src/use-cases/device-trust/recover-vault-access.ts;
:Require vault can be activated locally;
:Load local vault snapshot;
if (snapshot missing?) then (yes)
  :Throw VaultSnapshotNotFoundError;
  stop
endif
if (snapshot algorithm unsupported?) then (yes)
  :Throw UnsupportedAlgorithmSuiteError;
  stop
endif
:Find snapshot signing device in device slots;
if (signer missing?) then (yes)
  :Throw VaultSnapshotSignerNotTrustedError;
  stop
endif
:Verify local snapshot signature;
if (signature invalid?) then (yes)
  :Throw VaultSnapshotSignatureVerificationFailedError;
  stop
endif

:Convert recovery mnemonic to recovery key;
:Derive recovery vault-master-key protection key;
:Unwrap vaultMasterKey from recovery slot;
:Decrypt snapshot content into vault;
:Generate fresh recovered deviceId and timestamp;
:Generate deviceSlotKey and device signing key pair;
:Generate new local protection salts;
:Derive localRootKey from newMasterPassword;
:Derive localKeysProtectionKey;
:Wrap local keys payload;
:Derive device-slot vault-master-key protection key;
:Wrap vaultMasterKey for recovered device slot;
:Reset vault device profiles to recovered device;
:Remove syncConfig from recovered vault;
note right
Recovery intentionally creates a new local-only trust root.
Only the recovered device slot remains trusted in the new snapshot.
end note
:Build recovered snapshot with one device slot and recovery slot;
:Encrypt recovered vault content;
:Sign recovered snapshot with recovered device private key;
:Build device access material;
:Build unlocked vault session object;
:saveRecoveredLocalVault(access material, recovered snapshot);
if (commit unlocked session succeeds?) then (yes)
  :Return recovered vault;
  stop
else (no)
  :Throw original session commit failure;
  note right
  The recovered local vault records have already been persisted.
  RecoverVaultAccessUseCase does not remove them on commit failure;
  a later normal unlock can use the recovered access material.
  end note
  stop
endif
@enduml
