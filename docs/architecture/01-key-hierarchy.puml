@startuml 01-key-hierarchy
title Cryptographic Key Hierarchy

skinparam backgroundColor #FEFEFE
skinparam roundcorner 10
skinparam shadowing false
skinparam linetype ortho

skinparam rectangle {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
}

' === ROW 1: DERIVATION CHAIN ===
rectangle "Master Password" as input #FAFAFA
rectangle "PBKDF2\n600k iter" as pbkdf2 #E3F2FD
rectangle "**Master KEK**\n(RAM only)" as masterKek #E8F5E9

input -> pbkdf2
pbkdf2 -> masterKek

' === ROW 2: UNWRAPPED KEYS ===
rectangle "Ed25519\nSigning Key" as signKey #FFF3E0
rectangle "ECDH P-256\nExchange Key" as ecdhKey #FFF3E0

masterKek --> signKey : AES-GCM
masterKek --> ecdhKey : AES-GCM

' === ROW 3: KEY SLOTS ===
rectangle "Device Slot\nECDH-ES+A256GCMKW" as deviceSlot #FFF3E0
rectangle "Secret Key Slot\nA256GCMKW" as secretKeySlot #FFF3E0
rectangle "**Secret Key**\n(256-bit random)" as secretKey #E8F5E9

ecdhKey --> deviceSlot : derive KEK
secretKey --> secretKeySlot : wrap

' === ROW 4: VAULT KEY ===
rectangle "**Vault Key**\n(RAM only)" as vaultKey #E8F5E9

deviceSlot --> vaultKey : unwrap
secretKeySlot --> vaultKey : unwrap

' === ROW 5: DATA ===
rectangle "Encrypted Vault\n(AES-256-GCM)" as encData #FFCDD2

vaultKey --> encData : encrypt
signKey --> encData : sign

legend right
    |= Color |= Zone |
    | <#FAFAFA> | User Input |
    | <#E8F5E9> | Trusted RAM / User-held |
    | <#FFF3E0> | Stored (wrapped) |
    | <#FFCDD2> | Encrypted Data |
endlegend

@enduml
