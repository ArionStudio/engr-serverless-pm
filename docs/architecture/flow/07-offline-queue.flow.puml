@startuml 08-offline-queue-flow
title Offline Queue - Detailed Flow

skinparam backgroundColor #FEFEFE
skinparam roundcorner 10
skinparam shadowing false
skinparam conditionStyle diamond

|User|
start
:Perform action\n(Create/Update/Delete);

|Extension|
:Check network status;

if (Online?) then (yes)
    :Create signed envelope;
    :Upload to S3;
    if (Success?) then (yes)
        :Update local state;
        stop
    else (no)
        :Add to offline queue;
    endif
else (no)
    :Save locally (IndexedDB);
    :Add to pendingSync queue;
    note right
        Queue entry:
        {
          id: uuid,
          envelope: SignedEnvelope,
          createdAt: timestamp,
          retryCount: 0
        }
    end note
endif

|Background|
:Listen for online event;

:Network restored!;
repeat
    :Dequeue oldest entry;
    :Attempt upload;
    if (Success?) then (yes)
        :Remove from queue;
        :Update lastSyncTimestamp;
    else (no)
        :Increment retryCount;
        if (retryCount > maxRetries?) then (yes)
            :Move to deadLetter queue;
            :Notify user;
        else (no)
            :Wait (exponential backoff);
        endif
    endif
repeat while (Queue not empty?)

:All synced!;
stop
@enduml