@startuml 06-browser-save-password
title Save Password Flow (Browser Detection)

skinparam backgroundColor #FEFEFE
skinparam roundcorner 10
skinparam shadowing false

skinparam sequence {
    ArrowColor #1976D2
    LifeLineBorderColor #1976D2
    ParticipantBackgroundColor #E3F2FD
    ParticipantBorderColor #1976D2
}

participant "Web Page" as page
participant "Content Script" as content
participant "Background\nService Worker" as bg
participant "Extension\nPopup/Notification" as popup
actor User as user

== Form Submission Detection ==

user -> page : Fill login form
user -> page : Click submit

page -> content : Form submit event
activate content

content -> content : Capture credentials\nBEFORE navigation
note right of content
    **Capture Timing:**
    Must grab values before
    page navigates away.
    Use 'submit' event, not
    'beforeunload'.
end note

content -> content : Extract credentials
note right of content
    {
      url: location.href,
      username: usernameInput.value,
      password: passwordInput.value,
      title: document.title
    }
end note

content -> bg : Credentials captured
deactivate content

== Check for Existing Entry ==

activate bg
bg -> bg : Search vault by URL

alt Entry exists
    bg -> bg : Compare passwords

    alt Password unchanged
        bg -> bg : No action needed
    else Password changed
        bg -> popup : Prompt: Update password?
        popup -> user : "Update saved password\nfor example.com?"

        alt User approves
            user -> popup : Click "Update"
            popup -> bg : Update confirmed
            bg -> bg : Update entry in vault
            bg -> bg : Encrypt & save
            bg --> popup : Updated
            popup --> user : "Password updated"
        else User declines
            user -> popup : Click "Never" or dismiss
            popup -> bg : Declined
        end
    end

else New site (no entry)
    bg -> popup : Prompt: Save password?
    popup -> user : "Save password for\nexample.com?"

    note right of popup
        **Save Dialog Shows:**
        - Site favicon
        - Domain name
        - Username (editable)
        - Password (hidden)
        - Folder selector
    end note

    alt User approves
        user -> popup : Click "Save"
        popup -> bg : Save confirmed

        bg -> bg : Create new entry
        note right of bg
            {
              id: uuid(),
              title: "example.com",
              url: "https://example.com/login",
              username: "user@email.com",
              password: "encrypted...",
              createdAt: now(),
              modifiedAt: now()
            }
        end note

        bg -> bg : Add to vault
        bg -> bg : Encrypt vault
        bg -> bg : Save to IndexedDB
        bg -> bg : Queue for sync

        bg --> popup : Saved
        popup --> user : "Password saved"

    else User declines
        user -> popup : Click "Never for this site"
        popup -> bg : Add to blocklist
        bg -> bg : Store URL in blocklist
    end
end

deactivate bg

== Context Menu: Manual Save ==

user -> page : Right-click on page
page -> content : Context menu
content -> bg : Get context menu items

bg -> page : Show "Save password\nfor this site"

user -> page : Click menu item
page -> bg : Manual save triggered

bg -> popup : Open save dialog
popup -> user : Pre-filled form\n(editable fields)

user -> popup : Edit & confirm
popup -> bg : Save entry
bg -> bg : Add to vault

note right of bg
    **Manual save allows:**
    - Custom title
    - URL adjustment
    - Folder selection
    - Notes field
end note

@enduml
