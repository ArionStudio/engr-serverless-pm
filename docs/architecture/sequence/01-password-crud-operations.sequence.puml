@startuml 01-password-crud-operations
title Password CRUD Operations with Auto-Sync

skinparam backgroundColor #FEFEFE
skinparam roundcorner 10
skinparam shadowing false

skinparam sequence {
    ArrowColor #1976D2
    LifeLineBorderColor #1976D2
    ParticipantBackgroundColor #E3F2FD
    ParticipantBorderColor #1976D2
}

actor User as user
participant "Extension UI" as ui
participant "Core Layer" as core
participant "Crypto Adapter" as crypto
participant "Storage Adapter" as storage
participant "Sync Adapter" as s3
database "IndexedDB" as idb

== CREATE Password ==

user -> ui : Fill password form
ui -> core : createPassword(entry)
core -> core : Validate entry
core -> core : Add to vault (memory)

group #F5F5F5 Local Save
    core -> crypto : Encrypt vault
    crypto -> crypto : Generate new IV
    crypto -> core : Encrypted blob
    core -> storage : saveVault(blob)
    storage -> idb : PUT encrypted vault
    storage --> core : Success
end

group #E8F5E9 Auto-Sync (Safe Save)
    alt if Sync Enabled
        core -> core : Increment Revision
        core -> core : Update Timestamp
        core -> crypto : Sign Envelope (Ed25519)
        crypto --> core : Signature
        core -> s3 : uploadVault(SignedEnvelope)
        s3 --> core : Success
        core --> ui : Entry created & Synced
    else Sync Disabled
        core --> ui : Entry created
    end
end
ui --> user : Show in list

note right of crypto
    **Every save = new IV**
    Never reuse IV with same key
end note

== READ Password ==

user -> ui : Click password entry
ui -> core : getPassword(id)
core -> core : Lookup in memory vault
core --> ui : Password entry
ui --> user : Display details

user -> ui : Click "Copy Password"
ui -> ui : Copy to clipboard
ui -> ui : Start 30s timer
ui --> user : "Copied!"

note right of ui
    **Auto-clear clipboard**
    After 30 seconds, clear
    sensitive data from clipboard
end note

== UPDATE Password ==

user -> ui : Edit password form
ui -> core : updatePassword(id, changes)
core -> core : Update in memory vault
core -> core : Mark entry modified

group #F5F5F5 Local Save
    core -> crypto : Encrypt vault
    crypto -> core : New encrypted blob
    core -> storage : saveVault(blob)
    storage -> idb : PUT encrypted vault
    storage --> core : Success
end

group #E8F5E9 Auto-Sync (Safe Save)
    alt if Sync Enabled
        core -> core : Increment Revision
        core -> core : Update Timestamp
        core -> crypto : Sign Envelope (Ed25519)
        crypto --> core : Signature
        core -> s3 : uploadVault(SignedEnvelope)
        s3 --> core : Success
        core --> ui : Entry updated & Synced
    else Sync Disabled
        core --> ui : Entry updated
    end
end

== DELETE Password ==

user -> ui : Click delete
ui -> ui : Show confirmation
user -> ui : Confirm delete

ui -> core : deletePassword(id)
core -> core : Mark as tombstone
note right of core
    **Soft delete for sync**
    - Set deletedAt timestamp
    - Keep for conflict resolution
    - Permanent delete after sync
end note

group #F5F5F5 Local Save
    core -> crypto : Encrypt vault
    crypto -> core : New encrypted blob
    core -> storage : saveVault(blob)
    storage --> core : Success
end

group #E8F5E9 Auto-Sync (Safe Save)
    alt if Sync Enabled
        core -> core : Increment Revision
        core -> core : Update Timestamp
        core -> crypto : Sign Envelope (Ed25519)
        crypto --> core : Signature
        core -> s3 : uploadVault(SignedEnvelope)
        s3 --> ui : Success (Synced)
    else Sync Disabled
        core --> ui : Entry deleted
    end
end

ui --> user : Remove from list

== SEARCH ==

user -> ui : Type in search bar
ui -> core : searchPasswords(query)
core -> core : Filter in-memory vault
note right of core
    Search fields:
    - title
    - URL/domain
    - username
    - notes
end note
core --> ui : Matching entries
ui --> user : Display filtered list

@enduml